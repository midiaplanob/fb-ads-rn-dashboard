{
  "manifest_version": 3,
  "name": "RN Ad Tracker — Gastos Eleitorais",
  "short_name": "RN Ads",
  "version": "1.1.0",
  "description": "Monitora gastos de candidatos no Meta Ad Library para o Rio Grande do Norte. Captura dados automaticamente enquanto você navega.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.facebook.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.facebook.com/ads/library/*"],
      "js": ["content-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://www.facebook.com/ads/library/*"],
      "js": ["content-isolated.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "RN Ad Tracker"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
